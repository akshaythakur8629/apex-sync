generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "raptors"] // In production, you'd add schemas dynamically or use a different pattern
}

// --- Global (public schema) ---

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("organizations")
  @@schema("public")
}

model Permission {
  id          Int              @id @default(autoincrement())
  slug        String           @unique
  description String?
  module      String?
  roles       RolePermission[]

  @@map("permissions")
  @@schema("public")
}

model Role {
  id             Int              @id @default(autoincrement())
  organizationId Int?             @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime         @default(now()) @map("created_at")
  permissions    RolePermission[]
  users          UserRole[]

  @@unique([organizationId, name])
  @@map("roles")
  @@schema("public")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("public")
}

model User {
  id             Int           @id @default(autoincrement())
  organizationId Int?          @map("organization_id")
  email          String        @unique
  passwordHash   String        @map("password_hash")
  name           String?
  isSuperUser    Boolean       @default(false) @map("is_super_user")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  roles          UserRole[]

  @@map("users")
  @@schema("public")
}

model UserRole {
  userId Int  @map("user_id")
  roleId Int  @map("role_id")
  user   User @relation(fields: [userId], references: [id])
  role   Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("public")
}

// --- Tenant Data (raptors schema for example) ---

model Athlete {
  id               Int               @id @default(autoincrement())
  name             String
  position         String?
  status           String?           @default("available")
  medicalClearance String?           @default("cleared") @map("medical_clearance")
  loadTolerance    String?           @default("full") @map("load_tolerance")
  createdAt        DateTime          @default(now()) @map("created_at")
  snapshots        AthleteSnapshot[]
  conflicts        ConflictEvent[]
  decisions        Decision[]

  @@map("athletes")
  @@schema("raptors")
}

model AthleteSnapshot {
  id          Int      @id @default(autoincrement())
  athleteId   Int      @map("athlete_id")
  source      String
  metricType  String   @map("metric_type")
  value       Json
  capturedAt  DateTime @map("captured_at")
  createdAt   DateTime @default(now()) @map("created_at")
  athlete     Athlete  @relation(fields: [athleteId], references: [id])

  @@map("athlete_snapshots")
  @@schema("raptors")
}

model ConflictEvent {
  id              Int      @id @default(autoincrement())
  athleteId       Int      @map("athlete_id")
  signalsInvolved Json     @map("signals_involved")
  severity        String?  @default("medium")
  status          String?  @default("open")
  summary         String?
  createdAt       DateTime @default(now()) @map("created_at")
  athlete         Athlete  @relation(fields: [athleteId], references: [id])

  @@map("conflict_events")
  @@schema("raptors")
}

model Decision {
  id              Int                  @id @default(autoincrement())
  athleteId       Int                  @map("athlete_id")
  conflictEventId Int?                 @map("conflict_event_id")
  status          String?              @default("pending")
  priority        String?              @default("normal")
  deadline        DateTime?
  escalationLevel Int?                 @default(0) @map("escalation_level")
  createdAt       DateTime             @default(now()) @map("created_at")
  athlete         Athlete              @relation(fields: [athleteId], references: [id])
  assignments     DecisionAssignment[]
  rationales      RationaleRecord[]

  @@map("decisions")
  @@schema("raptors")
}

model DecisionAssignment {
  id         Int       @id @default(autoincrement())
  decisionId Int       @map("decision_id")
  userId     Int?      @map("user_id")
  assignedAt DateTime? @default(now()) @map("assigned_at")
  resolvedAt DateTime? @map("resolved_at")
  isActive   Boolean?  @default(true) @map("is_active")
  decision   Decision  @relation(fields: [decisionId], references: [id])

  @@map("decision_assignments")
  @@schema("raptors")
}

model RationaleRecord {
  id              Int      @id @default(autoincrement())
  decisionId      Int      @map("decision_id")
  userId          Int?     @map("user_id")
  keyFactors      Json?    @map("key_factors")
  tradeOffs       String?  @map("trade_offs")
  dissentingViews String?  @map("dissenting_views")
  confidenceLevel Int?     @map("confidence_level")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  decision        Decision @relation(fields: [decisionId], references: [id])

  @@map("rationale_records")
  @@schema("raptors")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  type      String?
  relId     Int?     @map("rel_id")
  title     String?
  message   String?
  isRead    Boolean? @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
  @@schema("raptors")
}
